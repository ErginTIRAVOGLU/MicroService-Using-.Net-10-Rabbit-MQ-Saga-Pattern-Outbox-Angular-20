    "version": "0.2.0",
    "compounds": [
        {
        "name": "Run All Microservices",
        "configurations": [
                "Basket",
                "Catalog",
                "Discount",
                "OrderService",
                "Payment",
                "Identity",
                "ApiGateway"
            ]
        }
    ],
    "configurations": [
        {
            "name": "Basket",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/Services/Basket/bin/Debug/net10.0/Basket.dll",
            "cwd": "${workspaceFolder}/Services/Basket",
            "justMyCode": true,
            "launchBrowser": {
                "enabled": false,
                "args": "https://localhost:8002/swagger"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Now listening on: (https?://\\S+)",
                "uriFormat": "%s/swagger"
            }
        },
        {
